# =========================================
# FICHIER .env.example
# Copie ce fichier en .env et remplis les valeurs
# =========================================

# URL de connexion à PostgreSQL
# En local (si PostgreSQL est installé sur ton PC) :
# DATABASE_URL=postgresql://postgres:TON_MOT_DE_PASSE@localhost:5432/budget_db
# Sur Render, cette valeur est fournie automatiquement
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME

# Port du serveur (Render le définit automatiquement, 3000 en local)
PORT=3000
