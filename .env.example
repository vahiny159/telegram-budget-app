# =========================================
# FICHIER .env.example
# Copie ce fichier en .env et remplis les valeurs
# =========================================

# URL de connexion à PostgreSQL (Neon.tech dans ce projet)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Token de ton bot Telegram (obtenu via @BotFather)
# OBLIGATOIRE en production pour valider les requêtes Telegram
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Port du serveur (Render le définit automatiquement, 3000 en local)
PORT=3000
